{
  "name": "playground.aauth.dev",
  "version": "0.1.0",
  "private": true,
  "description": "AAuth Protocol Playground - a reference agent server on Cloudflare Workers",
  "scripts": {
    "build:client": "esbuild client/protocol.js --bundle --format=iife --platform=browser --target=es2022 --outfile=public/protocol.js",
    "watch:client": "esbuild client/protocol.js --bundle --format=iife --platform=browser --target=es2022 --outfile=public/protocol.js --watch",
    "dev": "concurrently -n esbuild,wrangler -c yellow,cyan \"npm:watch:client\" \"wrangler dev\"",
    "predeploy": "npm run build:client",
    "deploy": "wrangler deploy",
    "generate-key": "node scripts/generate-key.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hellocoop/httpsig": "^1.4.0",
    "@simplewebauthn/server": "^13.1.1",
    "hono": "^4.7.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.0.0"
  }
}
